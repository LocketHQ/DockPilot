{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DockPilot",
  "version": "0.1.0",
  "identifier": "co.lockethq.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DockPilot",
        "width": 1320,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "decorations": true,
        "resizable": true,
        "backgroundColor": "#FAFAF7",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "© 2026 DockPilot",
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "resources": ["binaries/*"]
  }
}
