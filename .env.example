# LocketHQ — environment variables for local dev.
#
# The Tauri app doesn't require any secrets to start. Server-specific secrets
# (SSH keys, runner bearer tokens) are entered through the UI and stored
# in the app data dir.
#
# Set these only if you want to override defaults.

# Tauri-side logging
RUST_LOG=lockethq_app_lib=debug,lockethq_runner=debug

# Default port the runner listens on for new installs
LOCKETHQ_RUNNER_PORT=8765

# When set, the dev server listens on this address for mobile dev (not used on desktop)
# TAURI_DEV_HOST=
